# Copiá este archivo como `.env` y completá los valores.
# El .env NO se commitea (está en .gitignore).

# ─── WhatsApp (link wa.me) ─────────────────────────────────────────────
# Tu número internacional sin "+" ni espacios.
# Ejemplo Córdoba (Argentina): 549 351 555 1234 → 5493515551234
WHATSAPP_NUMERO=5493515551234

# ─── Email (SMTP) ─────────────────────────────────────────────────────
# Gmail: hay que crear una "app password" en https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tuemail@gmail.com
SMTP_PASS=abcd efgh ijkl mnop
EMAIL_FROM=tuemail@gmail.com
EMAIL_TO=tuemail@gmail.com
EMAIL_TO_CC=

# ─── Alertas activas ─────────────────────────────────────────────────
# Umbral mínimo de variación (%) para disparar alerta. Default: 5
ALERTAS_UMBRAL_PCT=5

# ─── Telegram (push al celular) ──────────────────────────────────────
# Cómo obtener:
# 1. En Telegram, hablale a @BotFather → /newbot → te da el token
# 2. Mandale un mensaje a tu bot recién creado
# 3. Andá a: https://api.telegram.org/bot<TOKEN>/getUpdates
# 4. Buscá "chat":{"id": NUMERO} → ese NUMERO es tu CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
